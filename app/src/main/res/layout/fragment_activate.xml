<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/montserrat"
            android:text="@string/introduction1"
            android:textColor="@android:color/white"
            android:textSize="36sp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/activate_button"
            android:layout_width="@dimen/activate_button_size"
            android:layout_height="@dimen/activate_button_size"
            android:layout_marginTop="@dimen/activate_button_margin_top"
            app:cardBackgroundColor="@color/white_mod"
            android:text="@string/activate"
            app:strokeWidth="5dp"
            app:strokeColor="#AAA"
            app:cardCornerRadius="@dimen/activate_button_size">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="@string/activate"
                    android:textAlignment="center"
                    android:fontFamily="@font/montserrat"
                    android:textColor="#000"
                    android:textSize="18sp" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Wallpaper assignment status section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/montserrat"
            android:text="@string/wallpaper_status_title"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:alpha="0.7" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Home screen status chip -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/homeStatusCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#55FFFFFF"
                app:cardBackgroundColor="#33FFFFFF">

                <TextView
                    android:id="@+id/homeStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/wallpaper_status_home_inactive"
                    android:textSize="10sp"
                    android:textColor="@android:color/white" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Lock screen status chip -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/lockStatusCard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#55FFFFFF"
                app:cardBackgroundColor="#33FFFFFF">

                <TextView
                    android:id="@+id/lockStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:fontFamily="@font/montserrat"
                    android:text="@string/wallpaper_status_lock_inactive"
                    android:textSize="10sp"
                    android:textColor="@android:color/white" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>

